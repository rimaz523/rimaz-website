<policies>
    <inbound>
        <base />
        <set-backend-service base-url="${backendBaseUrl}" />
        <rewrite-uri template="{{${logicAppUrlName}}}" copy-unmatched-params="false" />
        <rate-limit calls="60" renewal-period="30"/>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
